# KosherPlay Selenium service — environment variables.
# Set these in your host's dashboard (Render / Railway / Fly.io), NOT in code.

# CRM login (crm.kosherplay.com)
KP_USER=your-crm-username
KP_PWD=your-crm-password

# Shared secret — callers (the Supabase `kosherplay` edge function) must send
# this in the X-KP-Secret header. Use a long random string. Set the SAME value
# as the `KP_SHARED_SECRET` secret on the Supabase side.
KP_SHARED_SECRET=change-me-to-a-long-random-string

# Optional — already set by the Dockerfile, override only if your image differs.
# CHROME_BIN=/usr/bin/chromium
# CHROMEDRIVER=/usr/bin/chromedriver
