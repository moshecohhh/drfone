# Copy this file to `.env` and fill in your own Supabase project values.
# Both are PUBLIC (they ship in the browser bundle) and are protected by Row
# Level Security on the server. NEVER put the secret / service_role key here.
#
# Where to find them: Supabase dashboard -> Project Settings -> API
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxxxxxxx

# --- SERVER-ONLY secrets (Edge Functions) --------------------------------
# These are NOT VITE_-prefixed and must NEVER ship to the browser. Set them as
# Supabase function secrets, not in this client .env:
#   supabase secrets set CRM_USER=214382566 CRM_PWD=767676
# Used by the check-operator / send-ivr / check-kosher-imei functions to log in
# to crm.ideali.co.il.
# CRM_USER=214382566
# CRM_PWD=767676
#
# Used by the `kosherplay` edge function — it calls the KosherPlay CRM REST API
# directly over HTTP (no browser). KP_CRON_SECRET guards the cron-only
# `process_due` op (see supabase/schema_kp_timers.sql for the table + pg_cron).
# KP_USER=your-crm-username
# KP_PWD=your-crm-password
# KP_CRON_SECRET=change-me-to-a-long-random-string
